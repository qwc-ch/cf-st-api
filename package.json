{
    "name": "sillytavern-api",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "biome lint src/",
        "format": "biome format --write src/",
        "check": "biome check --write src/",
        "deploy": "wrangler deploy",
        "db:migrate": "wrangler d1 migrations apply sillytavern-db",
        "db:generate": "wrangler d1 migrations create"
    },
    "dependencies": {
        "@sveltejs/adapter-cloudflare": "^7.0.0",
        "@sveltejs/kit": "^2.20.0",
        "svelte": "^5.25.0",
        "vite": "^6.3.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@types/node": "^22.0.0",
        "typescript": "^5.9.0",
        "wrangler": "^4.0.0"
    }
}
